# =============================================================================
# Postmark Configuration – Templates V3
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# =============================================================================

# Postmark Server API Token (from API Tokens tab in your server)
# https://account.postmarkapp.com/servers/17253647/streams/outbound/overview
POSTMARK_API_TOKEN=34,3: # .env
# Default sender email (must be a verified Sender Signature in Postmark)
POSTMARK_SENDER=noreply@4unik.com.br

# Message Stream ID (default: "outbound" for transactional)
POSTMARK_MESSAGE_STREAM=outbound

# Platform URL
PLATFORM_URL=https://4unik.yoobe.me
